---
const currentPath = Astro.url.pathname
const isDev = import.meta.env.DEV

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/blog', label: 'Blog' },
  { href: '/trabajos', label: 'Trabajos' },
  { href: '/contacto', label: 'Contacto' },
]

const devVariants = [
  { href: '/inicio1', label: 'i1' },
  { href: '/inicio2', label: 'i2' },
  { href: '/inicio3', label: 'i3' },
  { href: '/inicio4', label: 'i4' },
  { href: '/inicio5', label: 'i5' },
  { href: '/inicio6', label: 'i6' },
  { href: '/inicio7', label: 'i7' },
]
---

<header class="gruvbox-nav fixed top-0 inset-x-0 z-50">
  <nav class="max-w-3xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="nav-logo flex items-center gap-2">
      <span class="nf nf-md-tea text-xl" aria-hidden="true"></span>
      Adal Michael García
    </a>

    <button class="mobile-toggle md:hidden p-2 text-[var(--gruvbox-fg)] hover:text-[var(--gruvbox-yellow)] transition-colors" aria-label="Menú de navegación" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

    <div class="nav-menu hidden md:flex items-center gap-1">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class={`nav-link ${currentPath === href ? 'active' : ''}`}
        >
          {label}
        </a>
      ))}

      {isDev && (
        <span class="nav-dev-group" title="Variantes de inicio (solo dev)">
          {devVariants.map(({ href, label }) => (
            <a
              href={href}
              class={`nav-link nav-link-dev ${currentPath === href ? 'active' : ''}`}
            >
              {label}
            </a>
          ))}
        </span>
      )}

      <a
        href="https://github.com/aodaru"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link inline-flex items-center gap-1"
        aria-label="GitHub"
      >
        <span class="nf nf-fa-github"></span>
        <span class="hidden sm:inline">Repo</span>
      </a>

      <button class="theme-toggle ml-2" aria-label="Cambiar tema" type="button">
        <svg class="bi" width="24" height="24" fill="currentColor">
          <use href="#sun" id="themeIcon"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.mobile-toggle')
  const menu = document.querySelector('.nav-menu')

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
    menu?.classList.toggle('flex')
    menu?.classList.toggle('flex-col')
    menu?.classList.toggle('absolute')
    menu?.classList.toggle('top-16')
    menu?.classList.toggle('inset-x-4')
    menu?.classList.toggle('p-4')
    menu?.classList.toggle('rounded-lg')
    menu?.classList.toggle('border')
    menu?.classList.toggle('border-[var(--gruvbox-yellow)]')
    menu?.classList.toggle('shadow-lg')
  })
</script>
