---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import BlogPostList from '../../../components/BlogPostList.astro'
import { getCollection } from 'astro:content'

interface PageProps {
  data: import('astro:content').CollectionEntry<'blog'>[]
  currentPage: number
  totalPages: number
  start: number
  end: number
  size: number
  url: { current: string; prev?: string; next?: string }
}

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const allPosts = await getCollection('blog')
  const publishedPosts = allPosts
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  return paginate(publishedPosts, { pageSize: 5 })
}

const props = Astro.props as { page: PageProps }
const posts = props.page.data
const currentPage = props.page.currentPage
const totalPages = props.page.totalPages
---

<BaseLayout
  title={currentPage === 1 ? 'Blog — Teapartydev' : `Blog — Página ${currentPage} — Teapartydev`}
  description="Artículos y tutoriales de Adal Michael García sobre desarrollo, sistemas y tecnología"
>
  <BlogPostList posts={posts} currentPage={currentPage} totalPages={totalPages} />
</BaseLayout>
