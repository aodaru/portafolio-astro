---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogPostList from '../../components/BlogPostList.astro'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('blog')
const publishedPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const pageSize = 5
const totalPages = Math.max(1, Math.ceil(publishedPosts.length / pageSize))
const currentPage = 1
const posts = publishedPosts.slice(0, pageSize)
---

<BaseLayout
  title="Blog — Teapartydev"
  description="Artículos y tutoriales de Adal Michael García sobre desarrollo, sistemas y tecnología"
>
  <BlogPostList posts={posts} currentPage={currentPage} totalPages={totalPages} />
</BaseLayout>
