---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  const tags = new Set(posts.flatMap((post) => post.data.tags))
  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: { tag },
  }))
}

const { tag } = Astro.props

const allPosts = await getCollection('blog')
const posts = allPosts
  .filter((post) => !post.data.draft && post.data.tags.includes(tag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<BaseLayout
  title={`#${tag} — Blog — Teapartydev`}
  description={`Artículos etiquetados con #${tag}`}
>
  <div class="max-w-3xl mx-auto px-4 py-12 animate-fade-in">
    <a
      href="/blog"
      class="inline-flex items-center gap-1 mb-6 no-underline transition-all duration-300 hover:opacity-80"
      style="color: var(--gruvbox-blue);"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
      </svg>
      Volver al blog
    </a>

    <h1 class="text-3xl font-bold mb-2" style="font-family: 'Courier New', monospace;">
      <span style="color: var(--gruvbox-green); font-weight: bold;">$</span>
      <span style="color: var(--gruvbox-yellow); margin-left: 0.5rem;">grep</span> -r "{tag}" posts/
      <span class="terminal-cursor"></span>
    </h1>
    <p class="mb-8 opacity-75">
      {posts.length} artículo{posts.length !== 1 ? 's' : ''} con la etiqueta
      <span style="color: var(--gruvbox-blue);">#{tag}</span>
    </p>

    {posts.length === 0 && (
      <p class="opacity-75">No hay artículos con esta etiqueta.</p>
    )}

    {posts.map((post, i) => (
      <a
        href={`/blog/${post.id}`}
        class="block no-underline"
        style={`animation: fadeInUp 0.6s ease-out ${i * 0.12}s both;`}
      >
        <article class="terminal-card cursor-pointer">
          <div class="terminal-header">
            <div class="terminal-dots">
              <span class="terminal-dot close"></span>
              <span class="terminal-dot minimize"></span>
              <span class="terminal-dot maximize"></span>
            </div>
            <span class="terminal-title">adalgarcia@portfolio: ~/blog/{post.id}</span>
          </div>
          <div class="terminal-body">
            <div class="flex items-center gap-2 mb-4 select-none">
              <span class="text-xs uppercase tracking-wider" style="color: var(--gruvbox-gray);">
                {new Date(post.data.date).toLocaleDateString('es-ES', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </span>
            </div>
            <h2 class="text-xl font-bold mb-2" style="color: var(--gruvbox-yellow);">
              {post.data.title}
            </h2>
            <p class="opacity-75 mb-3">{post.data.description}</p>
          </div>
        </article>
      </a>
    ))}
  </div>
</BaseLayout>
