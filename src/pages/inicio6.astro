---
import BaseLayout from '../layouts/BaseLayout.astro'
import TazaAscii from '../components/TazaAscii.astro'
import bio from '../data/bio.json'
---

<BaseLayout title="Teapartydev — Inicio 6" description="Variante taza interactiva — Adal Michael García">
  <div class="inicio6">
    <!-- Hero compacto con taza centrada -->
    <section class="hero6">
      <div class="hero6-inner">
        <div class="hero6-eyebrow">
          <span class="hero6-dot"></span>
          Available for new projects
        </div>

        <h1 class="hero6-title">
          Hi, I'm <span class="hero6-name">Adal</span>.<br />
          I build <span class="hero6-accent">systems</span> that last.
        </h1>

        <p class="hero6-sub">
          {bio.role} based in Chiriquí, Panamá — {bio.summary}
        </p>

        <div class="hero6-cta">
          <a href="/trabajos" class="hero6-btn hero6-btn-primary">
            View my work
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
          <a href="/contacto" class="hero6-btn hero6-btn-ghost">Get in touch</a>
        </div>

        <div class="hero6-taza-wrap" data-taza-parallax>
          <TazaAscii variant="svg" size="lg" label="Taza de café humeante" class="hero6-taza" />
        </div>
      </div>

      <div class="hero6-scroll" aria-hidden="true">
        <span>scroll</span>
        <div class="hero6-scroll-line"></div>
      </div>
    </section>

    <!-- About con taza sticky de fondo -->
    <section class="about6">
      <div class="about6-taza-bg" data-taza-sticky aria-hidden="true">
        <TazaAscii variant="svg" size="xl" label="" class="about6-taza" />
      </div>

      <div class="about6-content">
        <div class="sec6-label">01 — About</div>
        <h2 class="sec6-h2">A decade of keeping things running.</h2>
        <p class="sec6-p" data-reveal>
          I've spent the last 12+ years in the trenches of system administration — building
          reporting tools, data query layers, and small pieces of software that make teams
          faster. I care about reliability, clarity, and tools that respect the operator.
        </p>
        <p class="sec6-p" data-reveal>
          My work tends to live at the intersection of systems thinking and pragmatism:
          if a SQL query and a cron job can solve it, that's usually the right answer.
        </p>
        <a href="/blog" class="sec6-link" data-reveal>Read my notes →</a>
      </div>
    </section>

    <!-- Projects -->
    <section class="sec6 sec6-projects" data-reveal>
      <div class="sec6-grid">
        <div class="sec6-label">02 — Selected work</div>
        <div class="sec6-content">
          <h2 class="sec6-h2">Recent projects</h2>
          <p class="sec6-p sec6-p-sm">A few things I've built and shipped recently.</p>
        </div>
      </div>

      <div class="proj6-grid">
        <a href="/trabajos" class="proj6-card">
          <div class="proj6-icon" style="color: var(--gruvbox-yellow);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 3v18"/></svg>
          </div>
          <h3 class="proj6-title">Intranet & reporting</h3>
          <p class="proj6-desc">Sales reporting, dashboards, and internal tools for fast decision-making.</p>
          <span class="proj6-arrow">→</span>
        </a>

        <a href="/trabajos" class="proj6-card">
          <div class="proj6-icon" style="color: var(--gruvbox-blue);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
          </div>
          <h3 class="proj6-title">Web platforms</h3>
          <p class="proj6-desc">Custom websites and content systems tailored to small business needs.</p>
          <span class="proj6-arrow">→</span>
        </a>

        <a href="/trabajos" class="proj6-card">
          <div class="proj6-icon" style="color: var(--gruvbox-green);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 17l6-6-4-4M12 17l8-8"/><circle cx="20" cy="6" r="2"/></svg>
          </div>
          <h3 class="proj6-title">This portfolio</h3>
          <p class="proj6-desc">A static site built with Astro + GruvBox, replacing a WordPress theme.</p>
          <span class="proj6-arrow">→</span>
        </a>
      </div>
    </section>

    <!-- Hobbies -->
    <section class="sec6" data-reveal>
      <div class="sec6-grid">
        <div class="sec6-label">03 — Things I like</div>
        <div class="sec6-content">
          <h2 class="sec6-h2">Beyond the terminal</h2>
          <p class="sec6-p">
            When I'm not shipping code, you'll find me tinkering with electronics, IoT projects,
            and way too many video games.
          </p>
          <div class="hobby6-grid">
            {bio.hobbies.map((hobby) => (
              <span class="hobby6-chip">{hobby}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA con taza animada -->
    <section class="sec6 sec6-cta">
      <div class="cta6">
        <div class="cta6-taza-wrap" data-taza-cta>
          <TazaAscii variant="svg" size="lg" label="" class="cta6-taza" />
        </div>
        <h2 class="cta6-h2">Have something in mind?</h2>
        <p class="cta6-p">Let's talk about systems, tools, or a new project.</p>
        <div class="cta6-actions">
          <a href="mailto:hi@teapartydev.com" class="hero6-btn hero6-btn-primary">
            Say hello
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
          <div class="cta6-socials">
            <a href="https://github.com/aodaru" target="_blank" rel="noopener noreferrer" class="cta6-social">GitHub</a>
            <a href="https://twitter.com/aodaru" target="_blank" rel="noopener noreferrer" class="cta6-social">Twitter</a>
            <a href="https://www.linkedin.com/in/adal-garcia-471889197/" target="_blank" rel="noopener noreferrer" class="cta6-social">LinkedIn</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .inicio6 {
    overflow-x: hidden;
  }

  /* ================= HERO ================= */
  .hero6 {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 4rem;
  }

  .hero6-inner {
    max-width: 800px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero6-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    background: var(--gruvbox-card);
    border: 1px solid var(--gruvbox-card);
    border-radius: 999px;
    font-family: "MesloLG", monospace;
    font-size: 0.78rem;
    color: var(--gruvbox-fg);
    margin-bottom: 2rem;
    backdrop-filter: blur(8px);
    animation: fadeUp 0.7s ease-out 0.1s both;
  }

  .hero6-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gruvbox-green);
    box-shadow: 0 0 0 0 var(--gruvbox-green);
    animation: pulse 2s ease-out infinite;
  }

  .hero6-title {
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--gruvbox-fg);
    margin: 0 0 1.5rem;
    animation: fadeUp 0.7s ease-out 0.2s both;
  }

  .hero6-name {
    color: var(--gruvbox-yellow);
  }

  .hero6-accent {
    color: var(--gruvbox-orange);
    font-style: italic;
  }

  .hero6-sub {
    font-family: "MesloLG", monospace;
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.6;
    color: var(--gruvbox-gray);
    max-width: 56ch;
    margin: 0 0 2rem;
    animation: fadeUp 0.7s ease-out 0.3s both;
  }

  .hero6-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 3rem;
    animation: fadeUp 0.7s ease-out 0.4s both;
  }

  .hero6-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-radius: 6px;
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    transition: transform 0.2s, background 0.2s, color 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }

  .hero6-btn-primary {
    background: var(--gruvbox-yellow);
    color: var(--gruvbox-bg);
    box-shadow: 0 6px 20px -8px var(--gruvbox-yellow);
  }

  .hero6-btn-primary:hover {
    background: var(--gruvbox-orange);
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -8px var(--gruvbox-orange);
  }

  .hero6-btn-ghost {
    background: transparent;
    color: var(--gruvbox-fg);
    border: 1px solid var(--gruvbox-card);
  }

  .hero6-btn-ghost:hover {
    border-color: var(--gruvbox-yellow);
    color: var(--gruvbox-yellow);
    transform: translateY(-2px);
  }

  .hero6-taza-wrap {
    margin-top: 1rem;
    will-change: transform;
    animation: fadeUp 0.8s ease-out 0.5s both;
  }

  .hero6-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: "MesloLG", monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gruvbox-gray);
  }

  .hero6-scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--gruvbox-gray), transparent);
    position: relative;
    overflow: hidden;
  }

  .hero6-scroll-line::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: var(--gruvbox-yellow);
    animation: scrollLine 2s ease-in-out infinite;
  }

  /* ================= ABOUT + TAZA STICKY ================= */
  .about6 {
    position: relative;
    padding: 8rem 1.5rem;
    overflow: hidden;
  }

  .about6-taza-bg {
    position: absolute;
    top: 50%;
    right: -120px;
    transform: translateY(-50%);
    z-index: 0;
    opacity: 0.08;
    pointer-events: none;
    will-change: transform;
  }

  [data-theme="light"] .about6-taza-bg {
    opacity: 0.12;
  }

  .about6-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  /* ================= SECTIONS ================= */
  .sec6 {
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 1.5rem;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sec6.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sec6-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .sec6-grid {
      grid-template-columns: 200px 1fr;
      gap: 4rem;
    }
  }

  .sec6-label {
    font-family: "MesloLG", monospace;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gruvbox-yellow);
    padding-top: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .about6-content .sec6-label {
    margin-bottom: 1rem;
  }

  .sec6-h2 {
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--gruvbox-fg);
    margin: 0 0 1rem;
    max-width: 22ch;
  }

  .sec6-p {
    font-family: "MesloLG", monospace;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--gruvbox-fg);
    margin: 0 0 1.5rem;
    max-width: 60ch;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .sec6-p.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sec6-p-sm {
    color: var(--gruvbox-gray);
    font-size: 0.95rem;
  }

  .sec6-link {
    display: inline-block;
    font-family: "MesloLG", monospace;
    font-size: 0.95rem;
    color: var(--gruvbox-yellow);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: color 0.2s, transform 0.2s;
    opacity: 0;
    transform: translateY(20px);
  }

  .sec6-link.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sec6-link:hover {
    color: var(--gruvbox-orange);
    transform: translateX(4px);
  }

  /* Projects */
  .proj6-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .proj6-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .proj6-card {
    position: relative;
    display: block;
    padding: 1.75rem 1.5rem 4rem;
    background: var(--gruvbox-card);
    border: 1px solid var(--gruvbox-card);
    border-radius: 8px;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s;
  }

  .proj6-card:hover {
    transform: translateY(-6px);
    border-color: var(--gruvbox-yellow);
  }

  .proj6-icon {
    margin-bottom: 1.25rem;
  }

  .proj6-title {
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--gruvbox-fg);
    margin: 0 0 0.5rem;
  }

  .proj6-desc {
    font-family: "MesloLG", monospace;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--gruvbox-gray);
    margin: 0;
  }

  .proj6-arrow {
    position: absolute;
    bottom: 1.25rem;
    right: 1.5rem;
    font-size: 1.5rem;
    color: var(--gruvbox-yellow);
    transition: transform 0.3s;
  }

  .proj6-card:hover .proj6-arrow {
    transform: translate(4px, -4px);
  }

  /* Hobbies */
  .hobby6-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hobby6-chip {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--gruvbox-card);
    border: 1px solid var(--gruvbox-card);
    border-radius: 999px;
    font-family: "MesloLG", monospace;
    font-size: 0.88rem;
    color: var(--gruvbox-blue);
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }

  .hobby6-chip:hover {
    border-color: var(--gruvbox-blue);
    transform: translateY(-2px);
  }

  /* CTA con taza */
  .sec6-cta {
    padding-bottom: 8rem;
  }

  .cta6 {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem 2rem 4rem;
    background: var(--gruvbox-card);
    border: 1px solid var(--gruvbox-card);
    border-radius: 12px;
    backdrop-filter: blur(12px);
    position: relative;
  }

  .cta6-taza-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
    opacity: 0;
    transform: scale(0.6) translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cta6-taza-wrap.is-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .cta6-h2 {
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    color: var(--gruvbox-fg);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .cta6-p {
    font-family: "MesloLG", monospace;
    font-size: 1rem;
    color: var(--gruvbox-gray);
    margin: 0 0 2rem;
  }

  .cta6-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta6-socials {
    display: flex;
    gap: 1.5rem;
  }

  .cta6-social {
    font-family: "MesloLG", monospace;
    font-size: 0.88rem;
    color: var(--gruvbox-fg);
    text-decoration: none;
    transition: color 0.2s;
  }

  .cta6-social:hover {
    color: var(--gruvbox-yellow);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 var(--gruvbox-green); }
    70% { box-shadow: 0 0 0 10px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  @keyframes scrollLine {
    0% { top: -50%; }
    100% { top: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sec6,
    .sec6-p,
    .sec6-link,
    .cta6-taza-wrap,
    .hero6-eyebrow,
    .hero6-title,
    .hero6-sub,
    .hero6-cta,
    .hero6-taza-wrap,
    .hero6-scroll-line::after,
    .hero6-dot {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  // Reveal on scroll
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -80px 0px' }
  );

  document.querySelectorAll('[data-reveal], .sec6').forEach((el) => revealObserver.observe(el));

  // Parallax: taza del hero se mueve más lenta al hacer scroll
  const parallaxEl = document.querySelector('[data-taza-parallax]') as HTMLElement | null;
  if (parallaxEl && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let ticking = false;
    const update = () => {
      const rect = parallaxEl.getBoundingClientRect();
      const vh = window.innerHeight;
      if (rect.bottom > 0 && rect.top < vh) {
        const progress = (vh - rect.top) / (vh + rect.height);
        const offset = (progress - 0.5) * 60;
        parallaxEl.style.transform = `translateY(${offset.toFixed(1)}px)`;
      }
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  }

  // Sticky taza de fondo en About: sube y baja con scroll
  const stickyTaza = document.querySelector('[data-taza-sticky]') as HTMLElement | null;
  if (stickyTaza && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let tickingSticky = false;
    const updateSticky = () => {
      const rect = stickyTaza.getBoundingClientRect();
      const vh = window.innerHeight;
      if (rect.top < vh && rect.bottom > 0) {
        const progress = 1 - (rect.top / vh);
        const translateY = (progress - 0.5) * 100;
        const rotate = (progress - 0.5) * 8;
        stickyTaza.style.transform = `translateY(${translateY.toFixed(1)}px) translateY(-50%) rotate(${rotate.toFixed(1)}deg)`;
      }
      tickingSticky = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!tickingSticky) {
          requestAnimationFrame(updateSticky);
          tickingSticky = true;
        }
      },
      { passive: true }
    );
  }

  // CTA taza: animar al entrar en viewport
  const ctaTaza = document.querySelector('[data-taza-cta]') as HTMLElement | null;
  if (ctaTaza) {
    const ctaObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            ctaTaza.classList.add('is-visible');
            ctaObserver.unobserve(ctaTaza);
          }
        });
      },
      { threshold: 0.3 }
    );
    ctaObserver.observe(ctaTaza);
  }
</script>
