---
import BaseLayout from '../layouts/BaseLayout.astro'
import bio from '../data/bio.json'
---

<BaseLayout title="Teapartydev — Inicio 1" description="Variante editorial de inicio — Adal Michael García">
  <div class="inicio1">
    <div class="inicio1-grid">
      <!-- Main column -->
      <main class="inicio1-main">
        <header class="inicio1-hero">
          <p class="inicio1-eyebrow">Hello, I'm an indie engineer based in Panamá</p>
          <h1 class="inicio1-name">Adal<br /><span class="inicio1-name-accent">Michael</span><br />García</h1>
          <p class="inicio1-tagline">Digital Craftsman — Engineer / Sysadmin / Builder</p>
        </header>

        <section class="inicio1-section" data-reveal>
          <h2 class="inicio1-h2">Work</h2>
          <p class="inicio1-lead">
            <span class="inicio1-arrow">→</span> {bio.role}
          </p>
          <p class="inicio1-body">{bio.summary}</p>
          <ul class="inicio1-list">
            {bio.highlights.map((item) => (
              <li class="inicio1-list-item">
                <span class="inicio1-bullet">▸</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a href="/trabajos" class="inicio1-link">My portfolio →</a>
        </section>

        <section class="inicio1-section" data-reveal>
          <h2 class="inicio1-h2">Bio</h2>
          <ol class="inicio1-timeline">
            {bio.timeline.map((entry) => (
              <li class="inicio1-timeline-item">
                <span class="inicio1-year">{entry.year}</span>
                <p class="inicio1-timeline-text">{entry.description}</p>
              </li>
            ))}
          </ol>
        </section>

        <section class="inicio1-section" data-reveal>
          <h2 class="inicio1-h2">I ♥</h2>
          <p class="inicio1-body inicio1-hobbies">{bio.hobbies.join(' · ')}</p>
        </section>

        <section class="inicio1-section" data-reveal>
          <h2 class="inicio1-h2">On the web</h2>
          <ul class="inicio1-social">
            <li><a href="https://github.com/aodaru" target="_blank" rel="noopener noreferrer">github.com/aodaru</a></li>
            <li><a href="https://twitter.com/aodaru" target="_blank" rel="noopener noreferrer">twitter.com/aodaru</a></li>
            <li><a href="https://www.linkedin.com/in/adal-garcia-471889197/" target="_blank" rel="noopener noreferrer">linkedin.com/in/adal-garcia</a></li>
            <li><a href="https://www.instagram.com/aodarug/" target="_blank" rel="noopener noreferrer">instagram.com/aodarug</a></li>
          </ul>
        </section>
      </main>

      <!-- Sticky sidebar -->
      <aside class="inicio1-sidebar">
        <div class="inicio1-avatar">
          <img src="/img/Avatar.webp" alt="Adal Michael García" loading="lazy" />
        </div>
        <div class="inicio1-meta">
          <span class="inicio1-meta-key">role</span>
          <span class="inicio1-meta-val">engineer / sysadmin</span>
        </div>
        <div class="inicio1-meta">
          <span class="inicio1-meta-key">location</span>
          <span class="inicio1-meta-val">Chiriquí, Panamá</span>
        </div>
        <div class="inicio1-meta">
          <span class="inicio1-meta-key">since</span>
          <span class="inicio1-meta-val">2012</span>
        </div>
        <a href="mailto:hi@teapartydev.com" class="inicio1-cta">Get in touch</a>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .inicio1 {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .inicio1-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 900px) {
    .inicio1-grid {
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 6rem;
    }
  }

  /* Hero */
  .inicio1-hero {
    margin-bottom: 5rem;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  .inicio1-eyebrow {
    font-family: "MesloLG", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gruvbox-gray);
    margin-bottom: 1.5rem;
  }

  .inicio1-name {
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: clamp(3.5rem, 11vw, 8rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin: 0 0 1.5rem;
    color: var(--gruvbox-fg);
  }

  .inicio1-name-accent {
    color: var(--gruvbox-yellow);
    font-style: italic;
    font-weight: 400;
  }

  .inicio1-tagline {
    font-family: "MesloLG", monospace;
    font-size: 0.95rem;
    color: var(--gruvbox-gray);
    margin: 0;
    max-width: 28ch;
  }

  /* Sections */
  .inicio1-section {
    margin-bottom: 5rem;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .inicio1-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .inicio1-h2 {
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gruvbox-yellow);
    margin: 0 0 2rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--gruvbox-card);
  }

  .inicio1-lead {
    font-family: "Mononoki", monospace;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--gruvbox-orange);
    margin: 0 0 1.5rem;
  }

  .inicio1-arrow {
    color: var(--gruvbox-yellow);
    margin-right: 0.5rem;
  }

  .inicio1-body {
    font-family: "MesloLG", monospace;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--gruvbox-fg);
    margin: 0 0 1.5rem;
    max-width: 60ch;
  }

  .inicio1-hobbies {
    font-style: italic;
    color: var(--gruvbox-blue);
  }

  .inicio1-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  .inicio1-list-item {
    display: flex;
    gap: 0.75rem;
    padding: 0.6rem 0;
    border-bottom: 1px dashed var(--gruvbox-card);
    font-family: "MesloLG", monospace;
    line-height: 1.5;
  }

  .inicio1-list-item:last-child {
    border-bottom: none;
  }

  .inicio1-bullet {
    color: var(--gruvbox-yellow);
    flex-shrink: 0;
  }

  .inicio1-link {
    display: inline-block;
    font-family: "MesloLG", monospace;
    font-size: 0.95rem;
    color: var(--gruvbox-yellow);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: color 0.2s, transform 0.2s;
  }

  .inicio1-link:hover {
    color: var(--gruvbox-orange);
    transform: translateX(4px);
  }

  /* Timeline */
  .inicio1-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 60ch;
  }

  .inicio1-timeline-item {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-left: 2px solid var(--gruvbox-card);
    padding-left: 1.5rem;
    margin-left: 90px;
    position: relative;
  }

  .inicio1-timeline-item::before {
    content: "";
    position: absolute;
    left: -7px;
    top: 1.4rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--gruvbox-yellow);
    box-shadow: 0 0 0 3px var(--gruvbox-bg);
  }

  .inicio1-year {
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--gruvbox-yellow);
    margin-left: -105px;
  }

  .inicio1-timeline-text {
    font-family: "MesloLG", monospace;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    color: var(--gruvbox-fg);
  }

  /* Social */
  .inicio1-social {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .inicio1-social a {
    font-family: "MesloLG", monospace;
    font-size: 0.95rem;
    color: var(--gruvbox-fg);
    text-decoration: none;
    transition: color 0.2s, padding-left 0.2s;
    display: inline-block;
  }

  .inicio1-social a::before {
    content: "→";
    color: var(--gruvbox-yellow);
    margin-right: 0.5rem;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .inicio1-social a:hover {
    color: var(--gruvbox-yellow);
  }

  .inicio1-social a:hover::before {
    opacity: 1;
  }

  /* Sidebar */
  .inicio1-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .inicio1-sidebar {
      position: sticky;
      top: 6rem;
      align-self: start;
      height: fit-content;
    }
  }

  .inicio1-avatar {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--gruvbox-yellow);
    box-shadow: 0 0 0 6px var(--gruvbox-card);
    margin-bottom: 1rem;
  }

  .inicio1-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.95);
  }

  .inicio1-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--gruvbox-card);
    font-family: "MesloLG", monospace;
    font-size: 0.85rem;
  }

  .inicio1-meta-key {
    color: var(--gruvbox-gray);
    text-transform: lowercase;
  }

  .inicio1-meta-val {
    color: var(--gruvbox-fg);
    text-align: right;
  }

  .inicio1-cta {
    display: block;
    margin-top: 1rem;
    padding: 0.9rem 1.5rem;
    background: var(--gruvbox-yellow);
    color: var(--gruvbox-bg);
    text-align: center;
    text-decoration: none;
    font-family: "Mononoki", monospace;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s;
  }

  .inicio1-cta:hover {
    background: var(--gruvbox-orange);
    transform: translateY(-2px);
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .inicio1-hero,
    .inicio1-section {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
</script>
