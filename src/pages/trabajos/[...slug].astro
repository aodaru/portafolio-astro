---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection, getEntry, render } from 'astro:content'

export async function getStaticPaths() {
  const projects = await getCollection('projects')
  return projects
    .filter((p) => !p.data.draft)
    .map((project) => ({
      params: { slug: project.id },
      props: { id: project.id },
    }))
}

const { id } = Astro.props
const project = await getEntry('projects', id)
if (!project) return new Response(null, { status: 404 })
const { Content } = await render(project)
---

<BaseLayout
  title={`${project.data.title} — Trabajos — Teapartydev`}
  description={project.data.description}
>
  <div class="max-w-3xl mx-auto px-4 py-12 animate-fade-in">
    <a
      href="/trabajos"
      class="inline-flex items-center gap-1 mb-6 no-underline transition-all duration-300 hover:opacity-80"
      style="color: var(--gruvbox-blue);"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
      </svg>
      Volver a trabajos
    </a>

    <article>
      <header class="mb-8">
        <h1 class="text-3xl font-bold mb-4" style="color: var(--gruvbox-orange); font-family: 'Courier New', monospace;">
          {project.data.title}
        </h1>
        <p class="text-lg mb-4 opacity-80">{project.data.description}</p>
        {project.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {project.data.tags.map((tag) => (
              <span
                class="text-xs px-2 py-1 rounded"
                style="background: var(--gruvbox-card); color: var(--gruvbox-blue); border: 1px solid var(--gruvbox-blue);"
              >
                #{tag}
              </span>
            ))}
          </div>
        )}
        {project.data.url && (
          <a
            href={project.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded no-underline transition-all duration-300"
            style="background: var(--gruvbox-yellow); color: var(--gruvbox-bg);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1.002 1.002 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4.018 4.018 0 0 1-.128-1.287z"/>
              <path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243L6.586 4.672z"/>
            </svg>
            Visitar proyecto
          </a>
        )}
      </header>

      <div class="terminal-card">
        <div class="terminal-header">
          <div class="terminal-dots">
            <span class="terminal-dot close"></span>
            <span class="terminal-dot minimize"></span>
            <span class="terminal-dot maximize"></span>
          </div>
          <span class="terminal-title">adalgarcia@portfolio: ~/proyectos/{project.id}</span>
        </div>
        <div class="terminal-body prose-styles">
          <Content />
        </div>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .prose-styles {
    line-height: 1.8;
    font-size: 1rem;
  }

  .prose-styles :global(h2) {
    color: var(--gruvbox-yellow);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
    font-weight: 700;
  }

  .prose-styles :global(h3) {
    color: var(--gruvbox-orange);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .prose-styles :global(p) {
    margin-bottom: 1rem;
    color: var(--gruvbox-fg);
  }

  .prose-styles :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1rem;
  }

  .prose-styles :global(ul li) {
    margin-bottom: 0.25rem;
  }

  .prose-styles :global(ul li::before) {
    content: '▸ ';
    color: var(--gruvbox-yellow);
    font-weight: bold;
  }

  .prose-styles :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .prose-styles :global(ol li) {
    margin-bottom: 0.25rem;
  }

  .prose-styles :global(strong) {
    color: var(--gruvbox-yellow);
  }

  .prose-styles :global(code) {
    background: rgba(0, 0, 0, 0.2);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--gruvbox-green);
  }

  .prose-styles :global(pre) {
    background: rgba(0, 0, 0, 0.3);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1rem;
    border: 1px solid var(--gruvbox-gray);
  }

  .prose-styles :global(pre code) {
    background: none;
    padding: 0;
    color: var(--gruvbox-fg);
  }

  .prose-styles :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1rem 0;
    border: 2px solid var(--gruvbox-gray);
  }

  .prose-styles :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }

  .prose-styles :global(th) {
    text-align: left;
    padding: 0.5rem;
    border-bottom: 2px solid var(--gruvbox-orange);
    color: var(--gruvbox-orange);
    font-weight: 700;
  }

  .prose-styles :global(td) {
    padding: 0.5rem;
    border-bottom: 1px solid var(--gruvbox-gray);
  }

  .prose-styles :global(a) {
    color: var(--gruvbox-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-styles :global(blockquote) {
    border-left: 4px solid var(--gruvbox-orange);
    padding-left: 1rem;
    margin: 1rem 0;
    opacity: 0.85;
    font-style: italic;
  }

  .prose-styles :global(hr) {
    border: none;
    border-top: 2px solid var(--gruvbox-gray);
    margin: 2rem 0;
  }
</style>
