---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Blog — Teapartydev" description="Artículos y tutoriales de Adal Michael García">
  <div class="max-w-3xl mx-auto px-4 py-12 animate-fade-in">
    <h1 class="text-3xl font-bold mb-8" style="font-family: 'Courier New', monospace;">
      <span style="color: var(--gruvbox-green); font-weight: bold;">$</span>
      <span style="color: var(--gruvbox-yellow); margin-left: 0.5rem;">cat</span> posts.txt
      <span class="terminal-cursor"></span>
    </h1>

    {Array.from({ length: 3 }).map((_, i) => (
      <div class="terminal-card" style={`animation: fadeInUp 0.6s ease-out ${i * 0.15}s both;`}>
        <div class="terminal-header">
          <div class="terminal-dots">
            <span class="terminal-dot close"></span>
            <span class="terminal-dot minimize"></span>
            <span class="terminal-dot maximize"></span>
          </div>
          <span class="terminal-title">adalgarcia@portfolio: ~/blog/post-{i + 1}</span>
        </div>
        <div class="terminal-body">
          <div class="flex items-center gap-2 mb-4 select-none">
            <span class="text-xs uppercase tracking-wider" style="color: var(--gruvbox-gray);">Próximamente</span>
          </div>
          <h2 class="text-xl font-bold mb-2" style="color: var(--gruvbox-yellow);">Artículo en construcción</h2>
          <p class="opacity-75">Este espacio estará dedicado a artículos sobre desarrollo web, tecnología y más.</p>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
