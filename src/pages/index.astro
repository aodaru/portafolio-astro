---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Teapartydev — Inicio" description="Portafolio personal de Adal Michael García">
  <section class="max-w-4xl mx-auto px-4 py-20 text-center">
    <div class="w-28 h-28 mx-auto mb-6 rounded-full bg-accent/10 flex items-center justify-center overflow-hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
        <path d="M17.5 3.5c2 2 2 5.5 0 7.5l-5 5-5-5c-2-2-2-5.5 0-7.5s5.5-2 7.5 0Z"/>
        <path d="M12 3v14"/>
        <path d="M7 17h10"/>
        <path d="M10 21h4"/>
      </svg>
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold mb-4">
      Adal Michael García
    </h1>
    <p class="text-xl text-text-muted mb-8">
      Desarrollador web &amp; creador de contenido
    </p>
    <p class="text-text-muted max-w-lg mx-auto">
      Este portafolio está en construcción. Pronto encontrarás aquí mis trabajos, artículos y más.
    </p>
  </section>
</BaseLayout>
